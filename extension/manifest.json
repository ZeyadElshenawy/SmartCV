{
    "manifest_version": 3,
    "name": "SmartCV Agent",
    "version": "1.0",
    "description": "Parse job descriptions and send them to your SmartCV Kanban board instantly.",
    "permissions": [
      "activeTab",
      "storage"
    ],
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "images/icon16.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
      }
    },
    "content_scripts": [
      {
        "matches": [
          "*://*.linkedin.com/jobs/*",
          "*://*.indeed.com/viewjob*"
        ],
        "js": ["content.js"]
      }
    ]
}
