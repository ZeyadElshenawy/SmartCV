# Postgres (Supabase PgBouncer on port 6543, sslmode=require)
DATABASE_URL=postgresql://postgres.<project>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Groq — required (get a key at https://console.groq.com)
GROQ_API_KEY=gsk_...

# Optional: override the default Groq model
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional: HuggingFace fallback (only used in legacy paths)
# HF_API_KEY=hf_...
