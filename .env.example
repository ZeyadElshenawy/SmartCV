# Postgres (Supabase PgBouncer on port 6543, sslmode=require)
DATABASE_URL=postgresql://postgres.<project>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require

# ---------------------------------------------------------------------------
# Groq — required (get a key at https://console.groq.com)
# ---------------------------------------------------------------------------
# GROQ_API_KEY is the global default. Every LLM call falls back to this key
# if no task-specific key is set below.
GROQ_API_KEY=gsk_...

# Optional: override the default Groq model
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ---------------------------------------------------------------------------
# Per-task Groq credentials (OPTIONAL).
#
# Each LLM call site passes a `task` name; we look up GROQ_API_KEY_<TASK> /
# GROQ_MODEL_<TASK> first, then fall back to the global GROQ_API_KEY /
# GROQ_MODEL above. Set any subset — anything missing falls back.
#
# Use this to spread load across multiple Groq accounts so per-account
# rate limits don't bottleneck the whole pipeline.
#
# Recommended 4-key mapping (heaviest tasks isolated, lighter tasks share):
#
#   Key A (live, user-facing real-time):
#     - agent_chat       — Global agent chat (/agent/)
#     - interviewer      — Chatbot for profile building
#
#   Key B (heavy generative — slowest, most token-hungry):
#     - resume_gen       — Tailored resume generation
#     - gap_analyzer     — Two-phase gap analysis
#
#   Key C (extraction / validation — fast, deterministic):
#     - skill_extractor  — JD skill extraction
#     - parser           — CV parser LLM refinement
#     - validator        — llm_validator + semantic_validator
#
#   Key D (lower-priority generative — long-tail):
#     - cover_letter     — Cover letter generation
#     - outreach         — Outreach campaign drafting
#     - learning_path    — Learning path generator
#     - salary           — Salary negotiation script
#     - judge            — Benchmark LLM judge
#     - project_enricher — GitHub/Scholar/Kaggle → project bullets + dedupe (Phase 1)
#
# Uncomment and fill in to enable per-task routing:
#
# GROQ_API_KEY_AGENT_CHAT=gsk_KEY_A_...
# GROQ_API_KEY_INTERVIEWER=gsk_KEY_A_...
#
# GROQ_API_KEY_RESUME_GEN=gsk_KEY_B_...
# GROQ_API_KEY_GAP_ANALYZER=gsk_KEY_B_...
#
# GROQ_API_KEY_SKILL_EXTRACTOR=gsk_KEY_C_...
# GROQ_API_KEY_PARSER=gsk_KEY_C_...
# GROQ_API_KEY_VALIDATOR=gsk_KEY_C_...
#
# GROQ_API_KEY_COVER_LETTER=gsk_KEY_D_...
# GROQ_API_KEY_OUTREACH=gsk_KEY_D_...
# GROQ_API_KEY_LEARNING_PATH=gsk_KEY_D_...
# GROQ_API_KEY_SALARY=gsk_KEY_D_...
# GROQ_API_KEY_JUDGE=gsk_KEY_D_...
#
# GROQ_API_KEY_PROJECT_ENRICHER=gsk_KEY_C_...   # Shareable with key C — light, batched calls
#
# You can also override the model per task. Useful if you want a stronger
# model for resume_gen and a faster one for skill_extractor:
#
# GROQ_MODEL_RESUME_GEN=meta-llama/llama-4-maverick-17b-128e-instruct
# GROQ_MODEL_SKILL_EXTRACTOR=meta-llama/llama-4-scout-17b-16e-instruct

# ---------------------------------------------------------------------------
# GitHub — optional (raises aggregator rate limit 60→5000 req/hr per token)
# ---------------------------------------------------------------------------
# When set, profiles/services/github_aggregator.py attaches an Authorization
# header to its public-API requests. Unauthenticated calls share a 60-req/hr
# per-IP bucket; an authenticated call gets 5000/hr per token.
#
# Use a fine-grained PAT with NO scopes (it only reads public profile data,
# which is already public — token only authenticates for higher rate limit).
# Generate at https://github.com/settings/tokens/new — pick "Fine-grained",
# tick zero repository / account permissions, copy the token here.
#
# GITHUB_TOKEN=ghp_...

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional: HuggingFace fallback (only used in legacy paths)
# HF_API_KEY=hf_...
